APP_NAME=oneCompare API
ENVIRONMENT=development
TESTING=false

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/onecompare?retryWrites=true&w=majority
MONGODB_DB_NAME=onecompare

# Optional AI integration. If missing, the app uses a deterministic local scorer.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-nextjs-app.vercel.app

